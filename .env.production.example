# ============================================================
# CONFIGURATION PRODUCTION — NE JAMAIS COMMITER CE FICHIER
# Copier en .env et remplir les vraies valeurs
# ============================================================

# Générer avec : python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=REMPLACER_PAR_UNE_CLE_ALEATOIRE_DE_50_CHARS

# OBLIGATOIRE en production
DEBUG=False
DJANGO_ENV=production

# Uniquement vos domaines réels
ALLOWED_HOSTS=optilunette.bf,www.optilunette.bf

# Base de données (utilisez un mot de passe fort)
DB_NAME=lunette_db_prod
DB_USER=lunette_user_prod
DB_PASSWORD=MOT_DE_PASSE_FORT_ICI
DB_HOST=localhost
DB_PORT=5432

# SMS : mettre 'orange' ou 'wave' en production (pas 'mock')
SMS_PROVIDER=orange

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=votre@email.com
EMAIL_HOST_PASSWORD=MOT_DE_PASSE_APPLICATION_GMAIL
EMAIL_FROM=OptiLunette <votre@email.com>

# IA (OCR ordonnances)
GROQ_API_KEY=VOTRE_CLE_GROQ

# Logs
DJANGO_LOG_PATH=/var/log/optilunette/django.log
BACKUP_DIR=/var/backups/optilunette/
